<h3>Sign In</h3>

<form action="/admin" method="POST">
    <label for="username"><b>Username</b></label>
    <input type="text" id="login-user" name="username" placeholder="Enter Username" />

    <label for="password"><b>Password</b></label>
    <input type="password" name="password" placeholder="Enter Password"/>

    <input type="submit" value="Login" class="btn" />
</form>

<h3>Register</h3>
<form action="/register" method="POST">
    <label for="reg-user"><b>Username</b></label>
    <input type="text" id="login-pass" name="username" placeholder="Enter Username" />

    <label for="reg-pass"><b>Password</b></label>
    <input type="password" id="reg-pass" name="password" placeholder="Enter Password"/>

    <input type="submit" value="Register" class="btn" />
</form>